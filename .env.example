# API Keys Configuration
# Copy this file to .env and add your actual API keys

# OpenAI API Key (required for Codex and o3 evaluation)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional - Claude Code works without it)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Note: Claude Code and Gemini CLI work without API keys
# - Claude Code: Uses built-in authentication
# - Gemini CLI: Uses Google account authentication (free tier)

# Optional: Custom base URLs
# OPENAI_BASE_URL=https://api.openai.com/v1
